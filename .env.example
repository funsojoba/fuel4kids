APP_NAME="Fuel4Kids"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Toronto
APP_URL=https://fuel4kidscan.org

LOG_CHANNEL=single
LOG_LEVEL=warning

# --- Database (create in cPanel > MySQL Databases) ---
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_cpanel_db_name
DB_USERNAME=your_cpanel_db_user
DB_PASSWORD=your_cpanel_db_password

# File-based sessions/cache — no extra DB tables needed on shared hosting.
SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# --- Mail (create a mailbox in cPanel > Email Accounts, e.g. noreply@fuel4kidscan.org) ---
MAIL_MAILER=smtp
MAIL_HOST=mail.fuel4kidscan.org
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_USERNAME=noreply@fuel4kidscan.org
MAIL_PASSWORD=your_mailbox_password
MAIL_FROM_ADDRESS=noreply@fuel4kidscan.org
MAIL_FROM_NAME="${APP_NAME}"

# Where volunteer/partnership inquiries are sent
ORG_EMAIL=admin01@fuel4kidsca.org

# --- Stripe (Dashboard > Developers > API keys) ---
STRIPE_KEY=pk_live_xxx
STRIPE_SECRET=sk_live_xxx
# Dashboard > Developers > Webhooks > endpoint https://your-domain/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CURRENCY=cad
